# Production: set in Vercel → Project → Settings → Environment Variables

# Public site origin (no trailing slash). Used at build time for canonical + absolute og:image (/metadata/og.png).
# Example: https://your-domain.vercel.app or https://dez.example.com
VITE_SITE_URL=

# Optional: override leaderboard API origin only (default: same-origin /api/leaderboard/*)
# VITE_LEADERBOARD_API=https://your-domain.vercel.app

# Serverless only (never expose to the browser). Vercel Storage → Upstash Redis often injects:
KV_REST_API_URL=
KV_REST_API_TOKEN=
# Legacy / manual Upstash REST names (also read by lib/redis.ts and leaderboard handlers):
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
