# Production: set in Vercel → Project → Settings → Environment Variables

# Public site origin (no trailing slash). Used at build time for canonical + absolute og:image (/metadata/og.png).
# Example: https://your-domain.vercel.app or https://dez.example.com
VITE_SITE_URL=

# Optional: override leaderboard API base (default: same-origin /api/high-scores)
# VITE_LEADERBOARD_API=https://your-domain.vercel.app

# Serverless only (never expose to the browser). Create a Redis database at https://upstash.com
# → REST API → copy URL + token into Vercel env for Production (and Preview if you want previews to share the same board).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
